library(dplyr)
library(ggplot2)
library(ncdf4)
library(reshape2)
library(FactoMineR)
library(here)
library(rphylopic)
library(cowplot)
### Variables
name_baseline = "Yr2011"
yr_min = 40
###
data <- read.csv("data/biom_comp_run_status_quo.csv")
fg <- read.csv(("data/PugetSoundAtlantisFunctionalGroups_2024_V1_SQ.csv"))
data <- data[data$Year>yr_min, ]
#
data_mean <- left_join(fg, data, by = "longname") %>%
group_by(longname, run_name) %>%
mutate(biomass = mean(biomass)) %>%
distinct(longname, run_name, biomass, IsHeatMap, IsLTL, IsBenthos, IsFish, IsBiggerthanfish,Large_group, Large_group_alt, Large_group_alt2,Large_group_alt3) %>%
ungroup() %>%
group_by(longname) %>%
mutate(biomass_relative = (biomass-biomass[run_name == name_baseline])*100/ biomass[run_name == name_baseline])%>%
ungroup()
data_mean <- data_mean[!is.na(data_mean$longname),]
data_mean <- data_mean[data_mean$longname!="Carrion",] #Carrion not activated in the model
data_mean$biomass_relative[data_mean$biomass_relative>105] <-105
data_mean <- data_mean[data_mean$longname!="Labile detritus",]
data_mean <- data_mean[data_mean$run_name!=name_baseline,]
data_mean <- data_mean[data_mean$Large_group_alt3!="Bacteria",]
data_mean <- data_mean[data_mean$Large_group_alt3!="Bird",]
data_mean <- data_mean[data_mean$Large_group_alt3!="Detritus",]
data_mean <- data_mean[data_mean$Large_group_alt3!="Detritus",]
data_mean <- data_mean[data_mean$Large_group_alt3!="Shrimp & squid",]
unique.group <- unique(data_mean$Large_group_alt3)
data_mean2 <- data_mean[data_mean$Large_group!="Primary producers",]
ggplot(
data_mean2,
aes(
x = run_name,
y = biomass_relative,
fill = run_name
)
) +
geom_violin(width = 0.9, alpha = 0.5) +
stat_summary(
fun = median,
geom = "point",
color = "red3"
) +
facet_wrap(~ Large_group, scales = "free_x") +
scale_fill_brewer(palette = "Dark2") +
theme_minimal()+
ylab("Biomass relative change (%)")+
xlab("")+ theme(axis.text.x = element_text(size = 8))
data_mean2 <- data_mean[data_mean$Large_group=="Fish",]
data_mean2 <- data_mean2[data_mean2$Large_group_alt == "Salmon",]
levels(data_mean2$Large_group_alt2) <- c("Chinook (n = 15)", "Chum (n = 3)",
"Coho (n = 6)", "Other salmon (n = 3)")
data_mean2$Large_group_alt2[data_mean2$Large_group_alt2=="Chinook"] <- "Chinook (n = 15)"
data_mean2$Large_group_alt2[data_mean2$Large_group_alt2=="Chum"] <- "Chum (n = 3)"
data_mean2$Large_group_alt2[data_mean2$Large_group_alt2=="Coho"] <- "Coho (n = 6)"
data_mean2$Large_group_alt2[data_mean2$Large_group_alt2=="Other salmon"] <-"Other salmon (n = 3)"
ggplot(
data_mean2,
aes(
x = run_name,
y = biomass_relative,
fill = run_name
)
) +
geom_violin(width = 0.9, alpha = 0.5) +
stat_summary(
fun = median,
geom = "point",
color = "red3"
) +
facet_wrap(~ Large_group_alt2, scales = "free_x",  ncol=4) +
scale_fill_brewer(palette = "Dark2") +
theme_minimal()+
ylab("Biomass relative change (%)")+
xlab("")+ theme(axis.text.x = element_text(size = 8))
data_mean2 <- data_mean2[data_mean2$Large_group_alt2!="Other salmon (n = 3)",]
ggplot(
data_mean2,
