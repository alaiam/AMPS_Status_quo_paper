mutate(variable = mean(variable)) %>%
distinct(longname, scenario, variable, IsHeatMap, IsLTL, IsBenthos, IsFish, IsBiggerthanfish,Large_group, Large_group_alt, Large_group_alt2,Large_group_alt3) %>%
ungroup() %>%
group_by(longname) %>%
mutate(variable_relative = (variable-variable[scenario == name_baseline])*100/ variable[scenario == name_baseline])%>%
ungroup()
